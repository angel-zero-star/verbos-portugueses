  "private": true,
  "description": "European Portuguese verb conjugation flashcard game",
  "dependencies": {
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "recharts": "^2.12.0",
    "tailwind-merge": "^3.5.0"
  },
  "scripts": {
    "sync-version": "node scripts/sync-version.js",
    "bump-version": "node scripts/bump-version.js",
